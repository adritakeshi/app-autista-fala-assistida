generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id             String   @id @default(cuid())
  name           String
  age            Int?
  supportLevel   String
  favoriteReward String?
  reports        Report[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Board {
  id         String     @id @default(cuid())
  name       String
  description String?
  categories Category[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  level     Int      @default(1)
  order     Int      @default(0)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id        String   @id @default(cuid())
  label     String
  phrase    String
  emoji     String?
  imageUrl  String?
  favorite  Boolean  @default(false)
  level     Int      @default(1)
  order     Int      @default(0)
  categoryId String
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Routine {
  id        String   @id @default(cuid())
  title     String
  time      String
  dayOfWeek Int
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id                String   @id @default(cuid())
  profileId         String
  profile           Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sessionDate       DateTime
  goal              String
  notes             String
  promptLevel       String
  successfulRequests Int
  regulationNotes   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
